{
  "name": "bot-app",
  "module": "index.ts",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.1",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "dev": "bun --hot ./src/index.ts",
    "start": "bun run ./src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run ./src/db/migrate.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "grammy": "^1.40.1",
    "pg": "^8.19.0"
  }
}
